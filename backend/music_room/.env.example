# ─────────────────────────────────────────────
# Django
# ─────────────────────────────────────────────
SECRET_KEY=your-super-secret-django-key-change-this
DEBUG=True

# ─────────────────────────────────────────────
# YouTube Data API v3  (FREE)
# ─────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com
# 2. Create a project → Enable "YouTube Data API v3"
# 3. Credentials → Create credentials → API Key
# Free quota: 10,000 units/day (search = 100 units, video details = 1 unit)
YOUTUBE_API_KEY=AIzaSyATIVtcmfaf9m31ijHes_inhkOz2eeD3xE

# ─────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────
# All values from: https://supabase.com/dashboard → Your Project → Settings

# Database URI → Settings → Database → URI tab
# Use Transaction pooler (port 6543) for Django
SUPABASE_DB_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# Project URL → Settings → API
SUPABASE_URL=https://<project-ref>.supabase.co

# Anon/public key → Settings → API → Project API Keys
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Service role key → Settings → API → Project API Keys  ⚠️ Keep secret!
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ─────────────────────────────────────────────
# Redis (optional — only needed for multi-server WebSocket scaling)
# ─────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379
